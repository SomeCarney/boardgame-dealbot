.venv/
__pycache__/
*.pyc
.env

# Personal/sensitive documents should never live in a public repo's working
# tree at all, gitignore or not -- see note to move Taxes/ out entirely.
Taxes/
*.pdf

logs/

# Keepa best-sellers cache -- ASIN lists, not credentials, but ephemeral
# enough that committing it would just add noise to the history.
config/best_sellers_cache.json

# Facebook/Instagram daily-post-quota trackers -- pure runtime state (today's
# date + count), reset themselves daily, no reason to version them.
config/facebook_post_state.json
config/instagram_post_state.json

social_drafts.md
